{
  "name": "react-example",
  "description": "PARSER by FRESKO CT",
  "private": true,
  "version": "0.0.0",
  "main": "desktop/main.js",
  "author": "FRESKO CT",
  "type": "module",
  "scripts": {
    "dev": "tsx web/server.ts",
    "start": "node dist-server/server.js",
    "start:electron": "electron .",
    "build:vite": "vite build",
    "build:server": "npx -y esbuild web/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/server.js",
    "build": "npm run build:vite && npm run build:server",
    "dist": "npm run build && electron-builder --win --publish never",
    "preview": "vite preview",
    "clean": "rimraf dist dist-server dist-electron",
    "lint": "tsc --noEmit"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.fresko.parser",
    "productName": "PARSER",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PARSER",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "desktop/main.js",
      "shared/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "rimraf": "^6.1.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "telegraf": "^4.16.3",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
